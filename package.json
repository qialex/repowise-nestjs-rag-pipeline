{
  "name": "repowise-nestjs-rag-pipeline",
  "version": "0.0.21",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter @repowise/backend dev",
    "dev:frontend": "pnpm --filter @repowise/frontend dev",
    "build:shared": "pnpm --filter @repowise/shared build",
    "build:backend": "pnpm --filter @repowise/shared build && pnpm --filter @repowise/backend build",
    "build:frontend": "pnpm --filter @repowise/shared build && pnpm --filter @repowise/frontend build",
    "build": "pnpm --filter @repowise/shared build && pnpm -r --filter=!@repowise/shared build",
    "dev": "pnpm --filter @repowise/shared build && pnpm -r --parallel --filter=!@repowise/shared dev",
    "install:all": "pnpm install"
  }
}
