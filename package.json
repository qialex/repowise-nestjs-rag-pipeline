{
  "name": "repowise-nestjs-rag-pipeline",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter @repowise/backend dev",
    "dev:frontend": "pnpm --filter @repowise/frontend dev",
    "build:backend": "pnpm --filter @repowise/backend build",
    "build:frontend": "pnpm --filter @repowise/frontend build",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "install:all": "pnpm install"
  }
}
