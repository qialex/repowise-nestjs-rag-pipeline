# === LLM (Groq — chat) ===
# Get your free API key at https://console.groq.com
GROQ_API_KEY=gsk_...
LLM_MODEL=llama-3.1-8b-instant

# === Embeddings (Google Gemini) ===
# Get your free API key at https://aistudio.google.com
GOOGLE_API_KEY=AIza...

# === Upstash Redis (BullMQ queue) ===
REDIS_HOST=your-upstash-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password
REDIS_TLS=true

# === Upstash Vector ===
UPSTASH_VECTOR_URL=https://your-index.upstash.io
UPSTASH_VECTOR_TOKEN=your-upstash-vector-token

# === API Security ===
# Leave empty to disable auth (useful for local dev)
API_KEY=your-secret-api-key

# === App ===
PORT=3001
FRONTEND_URL=http://localhost:3000
