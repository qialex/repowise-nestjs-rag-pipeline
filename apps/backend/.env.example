# === LLM ===
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# === Upstash Redis (BullMQ queue) ===
REDIS_HOST=your-upstash-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-upstash-redis-password
REDIS_TLS=true

# === Upstash Vector ===
UPSTASH_VECTOR_URL=https://your-index.upstash.io
UPSTASH_VECTOR_TOKEN=your-upstash-vector-token

# === API Security ===
# Leave empty to disable auth (useful for local dev)
API_KEY=your-secret-api-key

# === App ===
PORT=3001
FRONTEND_URL=http://localhost:3000
